{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.3.1/resources/zpack-schema.json",
  "name": "zebar-rose-pine-dawn",
  "version": "0.1.0",
  "description": "Rose Pine Dawn top bar pack for Zebar with vanilla, GlazeWM, and Komorebi variants.",
  "tags": ["topbar", "rose-pine", "glazewm", "komorebi"],
  "previewImages": ["./resources/preview-image-1.png"],
  "repositoryUrl": "",
  "widgets": [
    {
      "name": "vanilla",
      "htmlPath": "./dist/vanilla/index.html",
      "zOrder": "normal",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": true,
      "transparent": true,
      "includeFiles": ["dist/vanilla/**/*", "dist/assets/**/*"],
      "caching": {
        "defaultDuration": 604800,
        "rules": []
      },
      "privileges": {
        "shellCommands": [
          {
            "program": "Taskmgr.exe",
            "argsRegex": ".*"
          },
          {
            "program": "zebar-nightlight-helper.exe",
            "argsRegex": "^status --json$"
          },
          {
            "program": "explorer.exe",
            "argsRegex": "^ms-settings:nightlight$"
          }
        ]
      },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "50px",
          "monitorSelection": {
            "type": "all"
          },
          "dockToEdge": {
            "enabled": false,
            "edge": null,
            "windowMargin": "0px"
          }
        }
      ]
    },
    {
      "name": "with-glazewm",
      "htmlPath": "./dist/with-glazewm/index.html",
      "zOrder": "normal",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": true,
      "transparent": true,
      "includeFiles": ["dist/with-glazewm/**/*", "dist/assets/**/*"],
      "caching": {
        "defaultDuration": 604800,
        "rules": []
      },
      "privileges": {
        "shellCommands": [
          {
            "program": "Taskmgr.exe",
            "argsRegex": ".*"
          },
          {
            "program": "zebar-nightlight-helper.exe",
            "argsRegex": "^status --json$"
          },
          {
            "program": "explorer.exe",
            "argsRegex": "^ms-settings:nightlight$"
          }
        ]
      },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "50px",
          "monitorSelection": {
            "type": "all"
          },
          "dockToEdge": {
            "enabled": false,
            "edge": null,
            "windowMargin": "0px"
          }
        }
      ]
    },
    {
      "name": "with-komorebi",
      "htmlPath": "./dist/with-komorebi/index.html",
      "zOrder": "normal",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": true,
      "transparent": true,
      "includeFiles": ["dist/with-komorebi/**/*", "dist/assets/**/*"],
      "caching": {
        "defaultDuration": 604800,
        "rules": []
      },
      "privileges": {
        "shellCommands": [
          {
            "program": "Taskmgr.exe",
            "argsRegex": ".*"
          },
          {
            "program": "zebar-nightlight-helper.exe",
            "argsRegex": "^status --json$"
          },
          {
            "program": "explorer.exe",
            "argsRegex": "^ms-settings:nightlight$"
          }
        ]
      },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "50px",
          "monitorSelection": {
            "type": "all"
          },
          "dockToEdge": {
            "enabled": false,
            "edge": null,
            "windowMargin": "0px"
          }
        }
      ]
    }
  ]
}
